# =============================================================================
# PariScore — .env production template (Phase 1)
# =============================================================================
# Ce fichier est un TEMPLATE. À copier sur le VPS comme .env et à remplir.
#
# ⚠️  CE FICHIER NE DOIT JAMAIS ÊTRE COMMITTÉ DANS GIT.
#     Il contient des secrets de production.
#
# ⚠️  Après avoir rempli ce fichier, vérifier les permissions :
#     chmod 600 .env
#     chown ubuntu:ubuntu .env
#
# ⚠️  Faire une sauvegarde chiffrée hors VPS :
#     gpg --symmetric --cipher-algo AES256 .env > .env.gpg
#     scp .env.gpg backup-server:/backups/pariscore/
#     shred -u .env.gpg  # supprimer la version non chiffrée sur le VPS
# =============================================================================

# === RUNTIME (obligatoire) ===================================================
NODE_ENV=production
PORT=3000
DATABASE_PATH=/home/ubuntu/pariscore/pariscore.db

# === AUTH / SÉCURITÉ (obligatoire — Phase 1) ================================

# JWT_SECRET : 64 hex chars minimum (32 octets). Générer avec :
#   openssl rand -hex 32
# ⚠️  CRITIQUE : ce secret signe tous les tokens JWT (admin + users + matchday).
#     Ne jamais committer, ne jamais partager, le rotater si compromis.
JWT_SECRET=3b9e1d45758690f7bdba1d5b27e3b9203fac677c7c077e558199eac466870c14

# ADMIN_PASSWORD : 12 chars minimum, fort (mix majuscules/minuscules/chiffres/symboles).
# Générer avec :
#   openssl rand -base64 18 | tr -d '/+=' | cut -c1-20
# ⚠️  Ancien mot de passe par défaut 'pariscore2026' EST À ROTATER.
ADMIN_PASSWORD=<REMPLIR—20-chars-fort>

# BETA_TESTER_PASSWORD : 12 chars minimum, fort.
# ⚠️  Ancien mot de passe par défaut 'Beta2026' EST À ROTATER.
BETA_TESTER_PASSWORD=<REMPLIR—20-chars-fort>

# ALLOWED_ORIGIN : origine autorisée pour CORS. En prod = URL du site.
# ⚠️  SANS ce var, CORS devient '*' + Allow-Credentials=true (invalide + dangereux).
ALLOWED_ORIGIN=https://pariscore.fr

# COOKIE_SECURE : 1 pour forcer le flag Secure sur les cookies (prod HTTPS).
COOKIE_SECURE=1

# API_RATE_LIMIT_MAX : 100 par défaut. Augmenter si légitime trafic.
API_RATE_LIMIT_MAX=100

# RG_REFRESH_TOKEN : token dédié pour la route /api/v1/admin/rg-refresh.
# Ne pas réutiliser ADMIN_PASSWORD. Générer avec :
#   openssl rand -hex 24
RG_REFRESH_TOKEN=<REMPLIR—48-hex-chars>

# === BYPASS FLAGS — À NE JAMAIS SETTER EN PROD ==============================
# ⚠️  Ces flags désactivent l'auth premium. Le serveur doit crasher au boot
#     si l'un d'eux est setté en production (après application du patch-002).
# MATCHES_AUTH_BYPASS=1   # INTERDIT EN PROD
# TENNIS_DEV_BYPASS=1     # INTERDIT EN PROD

# === HISTORIQUE / AUTH ======================================================
# HISTORY_AUTH_REQUIRED : 1 pour exiger l'auth sur /api/v1/history/* (recommandé).
HISTORY_AUTH_REQUIRED=1

# === DBs EXTERNES (obligatoire pour fonctionnalité complète) ================
# BSD (Bzzoiro Sports Data) — source primaire fixtures/standings/odds/live.
BSD_API_KEY=<from-https://sports.bzzoiro.com>
BSD_LIVE_WS_ENABLED=true   # false si pas d'abonnement WS ($3/mois)

# The Odds API — cotes prematch (multi-sport).
ODDS_API_KEY=<from-https://the-odds-api.com>

# API-Football (api-sports.io) — stats football.
API_FOOTBALL_KEY=<from-https://api-sports.io>

# Football-Data.org — compets EU.
FOOTBALL_DATA_API_KEY=<from-https://www.football-data.org>

# Sportmonks — fallback.
SPORTMONKS_API_KEY=<from-https://api.sportmonks.com>

# TheSportsDB — IMPORTANT : ne pas laisser vide (sinon clé publique '3' partagée).
THESPORTSDB_KEY=<from-https://www.thesportsdb.com>

# MatchStat — tennis fixtures/players/H2H.
MATCHSTAT_API_KEY=<from-https://matchstat.com>

# RapidAPI (si MatchStat via RapidAPI).
RAPIDAPI_KEY=<from-https://rapidapi.com>

# === SCRAPERS (optionnels, selon features activées) =========================
TENNIS_ABSTRACT_ENABLED=false   # true pour activer (risque ToS)
BETMINES_ENABLED=false
TNNS_LIVE_ENABLED=false         # ⚠️ légalement risqué (Sportradar licencié)
USE_CURL_IMPERSONATE=false
SACKMANN_SYNC_DISABLED=false
USE_API_FOOTBALL_ODDS=true
BSD_TENNIS_ENABLED=true
BETWATCH_DISABLED=false
FIRECRAWL_ENABLED=false         # ⚠️ ToS ATP Tour restrictives

# Betfair Exchange (WOM) — nécessite FLARESOLVERR pour bypass Cloudflare.
BETFAIR_APP_KEY=<optionnel>
BETFAIR_SESSION_TOKEN=<optionnel>
FLARESOLVERR_URL=<optionnel-http://localhost:8191>

# BrightData (proxy résidentiel) — pour scraping anti-détection.
# ⚠️  Coût + risque ToS. Désactivé par défaut.
# BRIGHTDATA_API_KEY=<optionnel>
# BRIGHTDATA_SERP_ZONE=serp

# === AI =====================================================================
# Gemini (AI Scout, EDA chat).
GEMINI_API_KEY=<from-https://ai.google.dev>

# CatBoost (football models).
CATBOOST_ENABLED=true
CATBOOST_PYTHON_BIN=python3

# === PUSH / EMAIL ===========================================================
# Web Push (VAPID). Générer avec : bunx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<base64url-public>
VAPID_PRIVATE_KEY=<base64url-private-NE-JAMAIS-EXPOSER>
VAPID_SUBJECT=mailto:contact@pariscore.fr

# SMTP (digest, alerts).
SMTP_HOST=<smtp.gmail.com-ou-autre>
SMTP_PORT=587
SMTP_USER=<contact@pariscore.fr>
SMTP_PASS=<mot-de-passe-applicatif>
SMTP_FROM=noreply@pariscore.fr

# === WEBHOOKS ===============================================================
# Discord (morning picks, alerts).
DISCORD_WEBHOOK_URL=<https://discord.com/api/webhooks/...>

# Telegram (picks, alerts).
TELEGRAM_BOT_TOKEN=<from-@BotFather>

# Stripe (paiements).
STRIPE_SECRET_KEY=<sk_live_...>
STRIPE_WEBHOOK_SECRET=<whsec_...>

# === ANALYTICS / OBSERVABILITÉ (consent-gated côté client) ==================
NEXT_PUBLIC_POSTHOG_KEY=<from-https://posthog.com>
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

SENTRY_DSN=<from-https://sentry.io>
NEXT_PUBLIC_SENTRY_DSN=<idem-SENTRY_DSN>
# SENTRY_ORG et SENTRY_PROJECT : CI seulement (source-map upload).
# SENTRY_ORG=<org-slug>
# SENTRY_PROJECT=<project-slug>

# === AFFILIÉS ===============================================================
# GA_POSTBACK_TOKEN : token pour /r/ redirect affilié Gambling-Affiliation.
GA_POSTBACK_TOKEN=<random-token-openssl-rand-hex-24>

# === PERF / TUNING ==========================================================
# RG (Roland Garros) Monte Carlo worker.
RG_WORKER_TIMEOUT_MS=60000
RG_INLINE_FALLBACK_MAX_DRAW=64

# Cron refresh interval for leagues (ms). Default from leagues_config.json cron_hours.
# LEAGUE_CRON_MS=<override>

# === URLs INTERNES (sidecars Docker) ========================================
# Sofascore sidecar Python.
SOFA_SERVICE_BASE=http://localhost:8765

# Transfermarkt API sidecar.
TRANSFERMARKT_API_URL=http://localhost:8000

# === SEO ====================================================================
NEXT_PUBLIC_SITE_URL=https://pariscore.fr

# === TRUSTED PROXIES (Phase 3 — BUG-016) ====================================
# IPs des reverse proxies autorisés à poser X-Forwarded-For.
# TRUSTED_PROXIES=127.0.0.1,::1

# =============================================================================
# FIN DU TEMPLATE
