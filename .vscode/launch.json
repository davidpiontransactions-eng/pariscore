{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun run dev",
      "cwd": "${workspaceFolder}",
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "http://localhost:3000",
        "uriFormat": "http://localhost:3000"
      }
    },
    {
      "name": "Next.js Build",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun run build",
      "cwd": "${workspaceFolder}",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Run Tests",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun test",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug Current Test File",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun test ${relativeFile}",
      "cwd": "${workspaceFolder}"
    }
  ]
}
