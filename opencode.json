    "skill": "allow",
    "todowrite": "allow",
    "question": "allow",
    "doom_loop": "ask",
    "external_directory": {
      "*": "allow",
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny",
      "~/.config/**": "deny",
      "~/secrets/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "/etc/**": "deny"
