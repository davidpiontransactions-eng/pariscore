    { "fr": "aucun", "key": "expert.high_conf_none", "file": "pariscore.js", "wrap": "js-template", "snippet": "`≥70% conf.` : 'aucun';" },
    { "fr": "🏟️ {0} ({1}% moy.)", "key": "expert.best_league_chip", "file": "pariscore.js", "wrap": "js-template", "snippet": "insights += `<div class=\"er-insight-chip\">🏟️ <strong>${bestLeague}</strong> (${Math.round(bestLeagueAvg)}% moy.)</div>`;" },
    { "fr": "📊 Marché {0} ({1}% moy.)", "key": "expert.best_market_chip", "file": "pariscore.js", "wrap": "js-template", "snippet": "📊 Marché <strong>${marketLabels[bestMarket] || bestMarket}</strong> (${Math.round(bestMarketAvg)}% moy.)" },
