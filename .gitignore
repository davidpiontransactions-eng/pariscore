!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/
# Large files (GitHub 100MB limit)
*.db
*.zip
download/

# =============================================================================
# Phase 1 security additions (AUDIT-2026-07 — BUG-002/007/008/027/048)
# =============================================================================
# Secrets
.jwt_secret

# SQLite WAL/SHM/journal (données users — non couverts par *.db)
*.db-wal
*.db-shm
*.db-journal
database.db
database.db-*

# Backups
*.bak
*.backup

# Logs d'erreur
*.err

# Scripts Ops avec IP VPS hardcodée
deploy-ovh.ps1
vps/deploy-ovh.ps1

# Python bytecode
__pycache__/
*.pyc

# Exports documents
exports/*.docx
exports/*.pdf
exports/*.xlsx

# =============================================================================
# Hardening post-purge (2026-07-13) — éviter nouvelle pollution historique
# Règles déduites des 3.5 Go de blobs purgés via git-filter-repo
# =============================================================================

# DB corrompues (sauvegardées par crash recovery — jamais à commiter)
*.db.corrupt-*
pariscore.db.corrupt-*

# Backups DB datés (cron deploy)
.deploy-backups/
*.db.20*       # snapshots datés type pariscore.db.20260705-032941
*.db-backup-*

# Backups historiques datés (cron daily backup)
historique_*.json.bak_*
historique_*.json.bak
*.json.bak_*

# Binaires / installateurs non-projet
*.exe
*.msi
*.dmg

# Archives volumineuses (zips de release)
download/*.zip
download/*.tar.gz
download/*.7z

# Dossiers internals (jamais à pousser)
.dolt/
beads/
.backups/
backups/

# Dumps et exports
*.dump
*.sql.gz
*.dump.gz

# Outils/scripts persos non-projet
prompt
.opencode/
.cursorsql/
