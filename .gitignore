# =============================================================================
# Phase 1 security additions (AUDIT-2026-07 — BUG-002/007/008/027/048)
# =============================================================================
# Secrets
.jwt_secret

# SQLite WAL/SHM/journal (données users — non couverts par *.db)
*.db-wal
*.db-shm
*.db-journal
database.db
database.db-*

# Backups
*.bak
*.backup

# Logs d'erreur
*.err

# Scripts Ops avec IP VPS hardcodée
deploy-ovh.ps1
vps/deploy-ovh.ps1

# Python bytecode
__pycache__/
*.pyc

# Exports documents
exports/*.docx
exports/*.pdf
exports/*.xlsx

# Beads / Dolt files (added by bd init)
.dolt/
.beads-credential-key
.beads/proxieddb/

