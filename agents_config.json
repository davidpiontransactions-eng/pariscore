{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "Manifeste de capacités des agents PariScore. Ce fichier n'est PAS chargé nativement par OpenCode (qui ne reconnait que opencode.json). Il sert de référence documentaire : l'allowlist des skills auto-découverts depuis .opencode/skills/ (junction vers .agents/tools/) et la déclaration des capacités externes (Graphify, Obsidian) que les agents peuvent invoquer via leurs instructions.",
  "_see_also": "https://opencode.ai/docs/skills/ — les skills sont auto-découverts depuis .opencode/skills/*/SKILL.md, AUCUNE clé 'skill' dans opencode.json.",

  "capabilities": {
    "graphify": {
      "description": "Knowledge graph du codebase (god nodes, communautés, relations cross-fichiers).",
      "graph_dir": "graphify-out/",
      "wiki": "graphify-out/wiki/index.md",
      "report": "graphify-out/GRAPH_REPORT.md",
      "invocation": {
        "query": "graphify query \"<question>\"",
        "path": "graphify path \"<A>\" \"<B>\"",
        "explain": "graphify explain \"<concept>\"",
        "update": "graphify update ."
      },
      "rules": [
        "Pour toute question codebase, lancer d'abord `graphify query` si graphify-out/graph.json existe.",
        "Utiliser graphify-out/wiki/index.md pour la navigation large plutôt que le raw source browsing.",
        "Lire graphify-out/GRAPH_REPORT.md seulement pour une revue d'architecture globale.",
        "Après modification de code, lancer `graphify update .` pour garder le graphe à jour (AST-only, sans coût API)."
      ]
    },

    "obsidian": {
      "description": "Accès au vault Obsidian local pour notes de recherche, ADRs et connaissances persistantes.",
      "vault_path": "${OBSIDIAN_VAULT_PATH:-C:/Users/David/Obsidian/pariscore}",
      "usage": [
        "Lire les ADRs et notes de design avant décision d'architecture.",
        "Consulter les notes de stratégies de paris pour cohérence métier.",
        "Ne JAMAIS écrire dans le vault sans instruction explicite de l'utilisateur."
      ]
    }
  },

