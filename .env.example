# The Odds API — free tier 500 req/mois (https://the-odds-api.com/#get-access)
ODDS_API_KEY=

# PostHog — free tier 1M events/mois (https://posthog.com/signup)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Web Push (VAPID) — generate with: bunx web-push generate-vapid-keys
# Public key is exposed client-side (NEXT_PUBLIC_*). Private key is SERVER-ONLY,
# NEVER expose it in client code. Subject should be a mailto: or https: URL.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@setpoint.local

# Sentry — create account at https://sentry.io/signup (free tier 5k errors/month)
# SENTRY_DSN is server-side, NEXT_PUBLIC_SENTRY_DSN is client-side (usually the same DSN).
# If unset, Sentry.init is a no-op and the app works normally (graceful degradation).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# SEO — absolute canonical URL of the deployed site.
# Used by sitemap.ts, robots.txt reference, JSON-LD (WebApplication + SportsEvent),
# OpenGraph/Twitter meta and the <link rel="canonical"> tag.
# No trailing slash. Falls back to https://setpoint.example if unset.
NEXT_PUBLIC_SITE_URL=https://setpoint.example

# Email (SMTP) — for value bet alerts. If SMTP_HOST is not set, emails are
# logged to the server console instead of being sent (graceful degradation,
# useful for dev / demo). Credentials are SERVER-ONLY — never prefix with
# NEXT_PUBLIC_ and never reference them from client code.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@setpoint.example
