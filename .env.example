# The Odds API — free tier 500 req/month (https://the-odds-api.com/#get-access)
ODDS_API_KEY=

# PostHog — free tier 1M events/month (https://posthog.com/signup)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Web Push (VAPID) — generate with: bunx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@setpoint.local

# Sentry — create account at https://sentry.io/signup (free tier 5k errors/month)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Email (SMTP) — for value bet alerts. If not set, emails are logged to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@setpoint.example

# Site URL (for SEO sitemap, OpenGraph, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://setpoint.example
