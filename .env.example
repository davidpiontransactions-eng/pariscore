# The Odds API — free tier 500 req/mois (https://the-odds-api.com/#get-access)
ODDS_API_KEY=

# ── Free sports APIs (2026-07-19) — see API/FreeProviders/MAP-API-PARISCORE-FIELDS.md ──
# TheRundown — free 20k datapoints/day, 3 books (https://therundown.io)
THERUNDOWN_API_KEY=
# PropLine — free 1000 req/day, props + 13 books + Kalshi/Polymarket (https://prop-line.com)
PROPLINE_API_KEY=
# Cloudbet Feed — free affiliate key (https://www.cloudbet.com/api/)
CLOUDBET_API_KEY=
# Oddsmagnet history-daily: no key — data.oddsmagnet.com/history-daily/
# SportScore live: no key — attribution link required (sportscore.com/developers)
# OpenLigaDB DE foot: no key — api.openligadb.de
# Jolpica F1 (Ergast successor): no key — api.jolpi.ca/ergast/f1/


# PostHog — free tier 1M events/mois (https://posthog.com/signup)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Web Push (VAPID) — generate with: bunx web-push generate-vapid-keys
# Public key is exposed client-side (NEXT_PUBLIC_*). Private key is SERVER-ONLY,
# NEVER expose it in client code. Subject should be a mailto: or https: URL.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@setpoint.local

# Sentry — create account at https://sentry.io/signup (free tier 5k errors/month)
# SENTRY_DSN is server-side, NEXT_PUBLIC_SENTRY_DSN is client-side (usually the same DSN).
# If unset, Sentry.init is a no-op and the app works normally (graceful degradation).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# SEO — absolute canonical URL of the deployed site.
# Used by sitemap.ts, robots.txt reference, JSON-LD (WebApplication + SportsEvent),
# OpenGraph/Twitter meta and the <link rel="canonical"> tag.
# No trailing slash. Falls back to https://setpoint.example if unset.
NEXT_PUBLIC_SITE_URL=https://setpoint.example

# Email (SMTP) — for value bet alerts. If SMTP_HOST is not set, emails are
# logged to the server console instead of being sent (graceful degradation,
# useful for dev / demo). Credentials are SERVER-ONLY — never prefix with
# NEXT_PUBLIC_ and never reference them from client code.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@setpoint.example

# BSD Sports API — tennis data (https://sports.bzzoiro.com)
# Requires Sports Addon subscription ($5/mo) for tennis endpoints
BSD_API_KEY=
BSD_TENNIS_ENABLED=false

# Prisma database — SQLite for dev, PostgreSQL for production
# Local: file-based SQLite. Prod: postgresql://user:pass@host:5432/db
DATABASE_URL="file:./dev.db"

# Scrapling — adaptive web scraping (serveur MCP natif déclaré dans .mcp.json).
# Aucune clé requise pour l'usage local (binaires navigateur Camoufox + Playwright
# déjà installés via `scrapling install`). Les variables ci-dessous sont optionnelles
# et servent à activer les proxies / solvers cloud quand le mode stealth local ne suffit pas.
# SCRAPLING_PROXY_URL=              # ex: http://user:pass@proxy.host:8080 (proxy résidentiel recommandé)
# SCRAPLING_SOLVE_CAPTCHA_API_KEY=  # clé solver cloud (2captcha/anticaptcha) pour CAPTCHA non-Cloudflare
# SCRAPLING_ENABLED=true            # feature flag pour wrappers maison (services/scraplingService.js)
